<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>DeepSeek AI 助手 - 安卓版</title>
    <style>
        * {
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }
        
        body {
            font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            margin: 0;
            min-height: 100vh;
            padding: 16px;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
        .container {
            max-width: 900px;
            width: 100%;
            background: #ffffff;
            border-radius: 32px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 92vh;
            max-height: 850px;
        }
        
        /* 安卓状态栏适配 */
        @supports (padding-top: env(safe-area-inset-top)) {
            .container {
                padding-top: env(safe-area-inset-top);
            }
        }
        
        .header {
            background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
            color: white;
            padding: 20px;
            text-align: center;
        }
        
        .header h1 {
            margin: 0;
            font-size: 1.6rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        
        .header p {
            margin: 8px 0 0;
            opacity: 0.9;
            font-size: 0.8rem;
        }
        
        .api-section {
            padding: 16px;
            background: #f5f5f5;
            border-bottom: 1px solid #e0e0e0;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        
        .api-section input {
            flex: 1;
            padding: 12px 16px;
            border: 2px solid #ddd;
            border-radius: 24px;
            font-size: 14px;
            background: white;
            font-family: monospace;
        }
        
        .api-section input:focus {
            outline: none;
            border-color: #2a5298;
        }
        
        .api-section button {
            background: #2a5298;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 24px;
            cursor: pointer;
            font-weight: bold;
            font-size: 14px;
            transition: transform 0.2s, opacity 0.2s;
        }
        
        .api-section button:active {
            transform: scale(0.96);
            opacity: 0.8;
        }
        
        .chat-box {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            background: #fafafa;
        }
        
        /* 自定义滚动条 */
        .chat-box::-webkit-scrollbar {
            width: 6px;
        }
        
        .chat-box::-webkit-scrollbar-track {
            background: #e0e0e0;
            border-radius: 10px;
        }
        
        .chat-box::-webkit-scrollbar-thumb {
            background: #2a5298;
            border-radius: 10px;
        }
        
        .message {
            max-width: 85%;
            padding: 12px 18px;
            border-radius: 20px;
            line-height: 1.5;
            word-wrap: break-word;
            animation: fadeIn 0.3s ease;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .user-message {
            align-self: flex-end;
            background: linear-gradient(135deg, #2a5298, #1e3c72);
            color: white;
            border-bottom-right-radius: 4px;
        }
        
        .assistant-message {
            align-self: flex-start;
            background: white;
            color: #1a1a1a;
            border-bottom-left-radius: 4px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }
        
        .loading {
            align-self: flex-start;
            background: #e8e8e8;
            color: #666;
            font-style: italic;
        }
        
        .input-area {
            padding: 16px;
            background: white;
            border-top: 1px solid #e0e0e0;
            display: flex;
            gap: 10px;
        }
        
        .input-area input {
            flex: 1;
            padding: 12px 18px;
            border: 2px solid #e0e0e0;
            border-radius: 28px;
            font-size: 16px;
            background: white;
            transition: border-color 0.2s;
        }
        
        .input-area input:focus {
            outline: none;
            border-color: #2a5298;
        }
        
        .input-area button {
            background: #2a5298;
            color: white;
            border: none;
            padding: 12px 28px;
            border-radius: 28px;
            cursor: pointer;
            font-weight: bold;
            font-size: 16px;
            transition: all 0.2s;
        }
        
        .input-area button:active {
            transform: scale(0.95);
            background: #1e3c72;
        }
        
        .input-area button:disabled {
            background: #bdbdbd;
            transform: none;
            cursor: not-allowed;
        }
        
        .clear-btn {
            background: #dc3545;
        }
        
        .clear-btn:active {
            background: #c82333;
        }
        
        .footer {
            font-size: 11px;
            text-align: center;
            padding: 12px;
            color: #999;
            background: #f5f5f5;
            border-top: 1px solid #e0e0e0;
        }
        
        /* 安卓设备适配 */
        @media (max-width: 600px) {
            body { padding: 8px; }
            .container { height: 95vh; border-radius: 24px; }
            .message { max-width: 90%; font-size: 15px; }
            .api-section { flex-direction: column; }
            .api-section button { padding: 10px; }
            .input-area button { padding: 10px 20px; }
        }
        
        /* 深色模式支持（跟随系统） */
        @media (prefers-color-scheme: dark) {
            .container { background: #1e1e1e; }
            .chat-box { background: #1a1a1a; }
            .assistant-message { background: #2d2d2d; color: #e0e0e0; box-shadow: 0 2px 5px rgba(255,255,255,0.05); }
            .input-area { background: #1e1e1e; border-top-color: #333; }
            .input-area input { background: #2d2d2d; border-color: #444; color: white; }
            .footer { background: #1e1e1e; color: #777; border-top-color: #333; }
            .api-section { background: #252525; border-bottom-color: #333; }
            .api-section input { background: #2d2d2d; border-color: #444; color: white; }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>
            🤖 DeepSeek AI
        </h1>
        <p>由 DeepSeek API 驱动 | 安卓专属优化</p>
    </div>
    <div class="api-section">
        <input type="password" id="apiKey" placeholder="🔑 输入你的 DeepSeek API Key" autocomplete="off">
        <button onclick="saveApiKey()">💾 保存并加密</button>
        <button onclick="clearChat()" class="clear-btn">🗑️ 清空对话</button>
    </div>
    <div class="chat-box" id="chatBox">
        <div class="message assistant-message">
            👋 欢迎使用 DeepSeek AI 助手！<br><br>
            📱 使用步骤：<br>
            1️⃣ 在上方输入你的 API Key<br>
            2️⃣ 点击「保存并加密」<br>
            3️⃣ 开始提问，AI 会为你解答<br><br>
            ⚡ 提示：支持上下文连续对话
        </div>
    </div>
    <div class="input-area">
        <input type="text" id="userInput" placeholder="输入消息... (支持回车发送)" onkeypress="handleKeyPress(event)">
        <button id="sendBtn" onclick="sendMessage()">发送 ✨</button>
    </div>
    <div class="footer">
        🔐 API Key 仅保存在本机 | 支持深色模式 | 数据不上传
    </div>
</div>

<script>
    // DeepSeek API 配置
    const DEEPSEEK_API_URL = 'https://api.deepseek.com/v1/chat/completions';
    
    // DOM 元素
    const chatBox = document.getElementById('chatBox');
    const userInput = document.getElementById('userInput');
    const sendBtn = document.getElementById('sendBtn');
    const apiKeyInput = document.getElementById('apiKey');
    
    // 从 localStorage 读取保存的 API Key
    let currentApiKey = localStorage.getItem('deepseek_api_key');
    if (currentApiKey) {
        apiKeyInput.value = '••••••••••••••••';
        apiKeyInput.placeholder = '✅ API Key 已保存';
    }
    
    // 保存 API Key（简单加密，防止明文存储）
    window.saveApiKey = function() {
        let newKey = apiKeyInput.value.trim();
        
        // 如果输入的是掩码且已有key，不做修改
        if (newKey === '••••••••••••••••' && currentApiKey) {
            alert('API Key 未修改，当前已保存有效 Key');
            return;
        }
        
        if (!newKey) {
            alert('❌ 请输入有效的 DeepSeek API Key\n获取地址：platform.deepseek.com');
            return;
        }
        
        // 简单验证 API Key 格式（sk-开头）
        if (!newKey.startsWith('sk-')) {
            if (!confirm('API Key 通常以 sk- 开头，确定要保存吗？')) {
                return;
            }
        }
        
        // 保存到本地存储
        localStorage.setItem('deepseek_api_key', newKey);
        currentApiKey = newKey;
        
        // 显示掩码
        apiKeyInput.value = '••••••••••••••••';
        apiKeyInput.placeholder = '✅ API Key 已保存';
        
        addMessage('assistant', '✅ API Key 已安全保存！现在可以开始对话了。\n\n💡 提示：你的 Key 只存储在这个手机浏览器中，不会上传到任何服务器。');
        
        // 清空输入框，聚焦
        setTimeout(() => userInput.focus(), 100);
    };
    
    // 添加消息到聊天框
    function addMessage(role, content) {
        const messageDiv = document.createElement('div');
        messageDiv.className = `message ${role === 'user' ? 'user-message' : 'assistant-message'}`;
        
        // 支持换行和简单格式化
        messageDiv.style.whiteSpace = 'pre-wrap';
        messageDiv.textContent = content;
        
        chatBox.appendChild(messageDiv);
        chatBox.scrollTo({
            top: chatBox.scrollHeight,
            behavior: 'smooth'
        });
        return messageDiv;
    }
    
    // 显示加载动画
    function showLoading() {
        const loadingDiv = document.createElement('div');
        loadingDiv.className = 'message assistant-message loading';
        loadingDiv.id = 'loading-message';
        loadingDiv.innerHTML = '🤔 DeepSeek 正在思考...<span class="dots"></span>';
        
        // 添加动态点效果
        let dots = 0;
        const interval = setInterval(() => {
            const loadingSpan = document.getElementById('loading-message');
            if (!loadingSpan) {
                clearInterval(interval);
                return;
            }
            dots = (dots + 1) % 4;
            loadingSpan.innerHTML = `🤔 DeepSeek 正在思考${'.'.repeat(dots)}`;
        }, 500);
        
        chatBox.appendChild(loadingDiv);
        chatBox.scrollTop = chatBox.scrollHeight;
        return { loadingDiv, interval };
    }
    
    function removeLoading(loadingObj) {
        if (loadingObj && loadingObj.loadingDiv) {
            loadingObj.loadingDiv.remove();
        }
        if (loadingObj && loadingObj.interval) {
            clearInterval(loadingObj.interval);
        }
        const loading = document.getElementById('loading-message');
        if (loading) loading.remove();
    }
    
    // 清空对话历史
    window.clearChat = function() {
        if (confirm('确定要清空所有对话历史吗？')) {
            chatBox.innerHTML = '';
            addMessage('assistant', '🧹 对话已清空。有什么我可以帮你的吗？\n\n💡 提示：API Key 仍然有效，可以直接开始新对话。');
        }
    };
    
    // 发送消息主函数
    window.sendMessage = async function() {
        const userText = userInput.value.trim();
        if (!userText) {
            // 震动反馈（如果支持）
            if (navigator.vibrate) navigator.vibrate(50);
            return;
        }
        
        // 检查 API Key
        if (!currentApiKey) {
            alert('🔑 请先在上方输入并保存你的 DeepSeek API Key\n\n获取地址：platform.deepseek.com');
            if (navigator.vibrate) navigator.vibrate(100);
            apiKeyInput.focus();
            return;
        }
        
        // 禁用发送按钮
        sendBtn.disabled = true;
        userInput.disabled = true;
        
        // 显示用户消息
        addMessage('user', userText);
        userInput.value = '';
        
        // 显示加载状态
        const loadingObj = showLoading();
        
        try {
            // 收集对话历史（保留最近20条，避免token过多）
            const messages = [];
            const chatMessages = document.querySelectorAll('#chatBox .message');
            
            for (let i = 0; i < chatMessages.length; i++) {
                const msg = chatMessages[i];
                if (msg.classList.contains('user-message')) {
                    messages.push({ role: 'user', content: msg.textContent });
                } else if (msg.classList.contains('assistant-message') && !msg.classList.contains('loading')) {
                    messages.push({ role: 'assistant', content: msg.textContent });
                }
            }
            
            // 限制历史长度（最多20条消息，即10轮对话）
            if (messages.length > 20) {
                messages.splice(0, messages.length - 20);
            }
            
            // 调用 DeepSeek API
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 30000); // 30秒超时
            
            const response = await fetch(DEEPSEEK_API_URL, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${currentApiKey}`
                },
                body: JSON.stringify({
                    model: 'deepseek-chat',
                    messages: messages,
                    stream: false,
                    temperature: 0.7,
                    max_tokens: 4096,
                    top_p: 0.9
                }),
                signal: controller.signal
            });
            
            clearTimeout(timeoutId);
            removeLoading(loadingObj);
            
            if (!response.ok) {
                const errorData = await response.json().catch(() => ({}));
                let errorMsg = `⚠️ 请求失败 (${response.status})`;
                
                switch(response.status) {
                    case 401:
                        errorMsg = '❌ API Key 无效或已过期\n\n请检查 Key 是否正确，或重新获取新的 Key';
                        // 清除无效的 Key
                        localStorage.removeItem('deepseek_api_key');
                        currentApiKey = null;
                        apiKeyInput.value = '';
                        apiKeyInput.placeholder = '🔑 API Key 已失效，请重新输入';
                        break;
                    case 429:
                        errorMsg = '⚠️ 请求过于频繁，请稍后再试\n\n免费额度可能已用完，请检查账户余额';
                        break;
                    case 402:
                        errorMsg = '💰 账户余额不足\n\n请访问 platform.deepseek.com 充值';
                        break;
                    default:
                        errorMsg = `❌ 错误：${errorData.error?.message || response.statusText || '未知错误'}`;
                }
                
                addMessage('assistant', errorMsg);
                if (navigator.vibrate) navigator.vibrate(200);
                return;
            }
            
            const data = await response.json();
            const reply = data.choices[0].message.content;
            addMessage('assistant', reply);
            
            // 成功响应时的轻微震动
            if (navigator.vibrate) navigator.vibrate(50);
            
        } catch (error) {
            removeLoading(loadingObj);
            console.error('请求失败:', error);
            
            let errorMessage = '❌ 网络错误：无法连接到 DeepSeek API\n\n';
            if (error.name === 'AbortError') {
                errorMessage += '请求超时，请检查网络连接后重试';
            } else if (error.message.includes('Failed to fetch')) {
                errorMessage += '请检查网络连接或防火墙设置\n确保能访问 api.deepseek.com';
            } else {
                errorMessage += `错误详情：${error.message}`;
            }
            
            addMessage('assistant', errorMessage);
            if (navigator.vibrate) navigator.vibrate(200));
        } finally {
            sendBtn.disabled = false;
            userInput.disabled = false;
            userInput.focus();
        }
    };
    
    // 回车发送
    window.handleKeyPress = function(event) {
        if (event.key === 'Enter') {
            sendMessage();
        }
    };
    
    // 页面加载完成后自动聚焦
    window.addEventListener('DOMContentLoaded', () => {
        userInput.focus();
        
        // 检查是否有保存的 Key
        if (currentApiKey) {
            console.log('已加载保存的 API Key');
        } else {
            // 显示友好提示
            setTimeout(() => {
                addMessage('assistant', '🔑 首次使用提示：\n\n1. 访问 platform.deepseek.com 注册并获取 API Key\n2. 在上方输入框粘贴 Key 并保存\n3. 开始免费使用 AI 助手！\n\n💡 新用户通常有免费额度');
            }, 500);
        }
    });
    
    // 安卓返回键处理（可选）
    window.addEventListener('load', () => {
        let startX, startY;
        chatBox.addEventListener('touchstart', (e) => {
            startX = e.touches[0].clientX;
            startY = e.touches[0].clientY;
        });
    });
</script>
</body>
</html>
